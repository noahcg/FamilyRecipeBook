# Supabase — from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-only, never expose to the browser
# Used to bypass RLS for privileged operations (e.g. accepting invitations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudflare Workers AI — server-only, used for pantry-based recipe ideas
# Get these from Cloudflare Dashboard → Workers AI → Use REST API
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_WORKERS_AI_API_TOKEN=your-workers-ai-token
CLOUDFLARE_WORKERS_AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# Optional paid fallback provider. Leave unset to avoid OpenAI charges.
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_RECIPE_MODEL=gpt-5-mini
